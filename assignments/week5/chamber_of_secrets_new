import time

GAME_TITLE = "The Chamber of Secrets"
START_LIVES = 3
CORRECT_WEAPON = "sword"


# To print the text slowly
def slow_print(text: str):
    print(text)
    time.sleep(1)


# greeting text
# It returns a string instead of printing directly
def custom_greeting(name="Harry", greeting="Welcome"):
    return greeting + ", " + name + "!"


# To check the weapon and to return damage points
def calculate_damage(weapon: str):

    if weapon == CORRECT_WEAPON:
        return 100

    elif weapon == "wand":
        return 50

    else:
        return 10

  # The user chooses a weapon 
def choose_weapon():

    weapon = input("Choose a weapon: sword, wand or stone: ")

    return weapon.lower()


# the fight scene
def fight_scene(lives: int):

    slow_print("The Basilisk is in front of you.")

    weapon = choose_weapon()

    damage = calculate_damage(weapon)

    # Check if the player wins
    if damage == 100:
        slow_print("You chose the sword.")
        slow_print("You defeated the Basilisk!")
        return True

    # Player loses one life
    else:
        slow_print("That was not strong enough.")

        # Reduce lives by 1
        lives = lives - 1

        print("Lives left:", lives)

        # If there are still lives left, the function starts again
        if lives > 0:
            return fight_scene(lives)

        else:
            slow_print("You lost the game.")
            return False


def main():

    print(custom_greeting(name="Harry", greeting="Welcome"))

    slow_print("You enter " + GAME_TITLE + ".")
    slow_print("Your goal is to defeat the Basilisk.")

    ready = input("Are you ready? yes or no: ")

    if ready.lower() == "yes":
        fight_scene(START_LIVES)

    else:
        slow_print("You leave the chamber. Game over.")


# Start the whole program
main()
